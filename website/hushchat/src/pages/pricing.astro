---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pricing - HushChat" description="Simple, transparent pricing for teams of all sizes." activePage="pricing">

  <!-- HERO -->
  <section class="pricing-hero section-padding">
    <div class="container">
      <h1>Choose How You Connect</h1>
      <p class="pricing-subtitle">
        Whether you want us to handle everything or prefer full control, HushChat fits your workflow and budget.
      </p>
    </div>
  </section>

  <!-- PRICING CARDS -->
  <section class="pricing-cards-section">
    <div class="container">
      <div class="pricing-cards">
        <!-- Cloud Hosted -->
        <div class="pricing-card pricing-card--popular">
          <span class="popular-badge">Most Popular</span>
          <div class="pricing-card-icon pricing-card-icon--purple">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#6B4EFF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"></path>
            </svg>
          </div>
          <h3 class="pricing-card-title">Cloud Hosted</h3>
          <p class="pricing-card-desc">
            We handle the infrastructure. You focus on your team. Get started in minutes with zero maintenance.
          </p>
          <div class="pricing-price">
            <span class="pricing-currency">$</span>
            <span class="pricing-amount">0.29</span>
            <span class="pricing-period">/user/month</span>
          </div>
          <p class="pricing-setup"><strong>$99</strong> one-time setup fee</p>
          <ul class="pricing-features">
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6B4EFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Fully managed infrastructure
            </li>
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6B4EFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Automatic updates & security patches
            </li>
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6B4EFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              99.9% uptime SLA guaranteed
            </li>
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6B4EFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Priority email support
            </li>
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6B4EFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Custom workspace branding
            </li>
          </ul>
          <a href="/contact" class="btn-primary pricing-btn">Get started</a>
        </div>

        <!-- Enterprise -->
        <div class="pricing-card">
          <div class="pricing-card-icon pricing-card-icon--green">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
              <path d="M2 17l10 5 10-5"></path>
              <path d="M2 12l10 5 10-5"></path>
            </svg>
          </div>
          <h3 class="pricing-card-title">Enterprise</h3>
          <p class="pricing-card-desc">
            Tailored solutions for large teams. Get dedicated support, custom integrations, and flexible deployment options.
          </p>
          <div class="pricing-price">
            <span class="pricing-amount pricing-amount--custom">Custom</span>
          </div>
          <p class="pricing-setup">Flexible pricing for your needs</p>
          <ul class="pricing-features pricing-features--green">
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Everything in Cloud Hosted
            </li>
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Dedicated account manager
            </li>
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Custom SLA & 24/7 support
            </li>
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Advanced security
            </li>
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              On-premise deployment option
            </li>
          </ul>
          <a href="/contact" class="btn-dark pricing-btn">Contact Sales</a>
        </div>
      </div>
    </div>
  </section>

  <!-- COST CALCULATOR -->
  <section class="calculator-section section-padding">
    <div class="container">
      <div class="calculator">
        <div class="calc-header">
          <h2 class="calc-title">Calculate Your Cost</h2>
          <p class="calc-subtitle">See exactly what you'll pay with Cloud Hosted</p>
        </div>

        <div class="calc-content">
          <div class="calc-input">
            <label for="calc-slider">Number of Team Members</label>
            <div class="slider-wrap">
              <input type="range" class="calc-slider" id="calc-slider" min="5" max="500" value="25" />
              <input type="number" class="calc-number-input" id="calc-users" value="25" min="5" max="1000" />
            </div>
          </div>

          <div class="calc-result">
            <div class="result-row">
              <span class="result-label">Monthly cost</span>
              <span class="result-value" id="calc-monthly">$7.25</span>
            </div>
            <div class="result-row">
              <span class="result-label">One-time setup</span>
              <span class="result-value">$99.00</span>
            </div>
            <div class="result-row result-row--total">
              <span class="result-label">First year total</span>
              <span class="result-total" id="calc-yearly">$186.00</span>
            </div>
          </div>
        </div>

        <div class="calc-cta">
          <a href="/contact" class="btn-primary">Get Started</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ SECTION -->
  <section class="faq-section section-padding">
    <div class="container">
      <h2 class="faq-heading">FAQs</h2>

      <div class="faq-list">
        <details class="faq-item" open>
          <summary class="faq-question">
            What's included in the $99 setup fee?
            <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </summary>
          <div class="faq-answer">
            <p>The setup fee covers your dedicated workspace provisioning, initial configuration, custom domain setup (if needed), data migration assistance, and a personalized onboarding session to get your team up and running quickly.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">
            Is there a minimum number of users?
            <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </summary>
          <div class="faq-answer">
            <p>Yes, Cloud Hosted plans start at a minimum of 5 users. This ensures you get the best team collaboration experience from day one.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">
            What's the difference between Cloud and Enterprise?
            <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </summary>
          <div class="faq-answer">
            <p>Cloud Hosted is our fully managed solution where we handle all infrastructure, updates, and maintenance. Enterprise gives you everything in Cloud plus dedicated support, custom SLAs, advanced security features, and the option to deploy on your own infrastructure.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">
            Can I upgrade from Cloud to Enterprise later?
            <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </summary>
          <div class="faq-answer">
            <p>Absolutely. You can upgrade from Cloud Hosted to Enterprise at any time. Our team will handle the migration seamlessly, and all your data, conversations, and settings will be preserved.</p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA SECTION -->
  <section class="pricing-cta section-padding">
    <div class="container">
      <div class="pricing-cta-card">
        <h2>Ready to Transform Your Team Communication?</h2>
        <p class="pricing-cta-subtitle">
          Join hundreds of teams already using HushChat to collaborate better.
        </p>
        <a href="/contact" class="btn-primary">Get started</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* HERO */
  .pricing-hero {
    background: var(--color-white);
    text-align: center;
    padding-bottom: 2rem;
  }

  .pricing-hero h1 {
    font-size: 2.75rem;
    font-weight: 800;
    margin-bottom: 1rem;
  }

  .pricing-subtitle {
    font-size: 1.0625rem;
    color: var(--color-muted);
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* PRICING CARDS */
  .pricing-cards-section {
    background: var(--color-light-bg);
    padding: 3rem 0 4rem;
  }

  .pricing-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    max-width: 820px;
    margin: 0 auto;
  }

  .pricing-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 2.5rem 2rem;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .pricing-card--popular {
    border-color: var(--color-primary);
    border-width: 2px;
  }

  .popular-badge {
    position: absolute;
    top: -12px;
    left: 2rem;
    background: var(--color-primary);
    color: var(--color-white);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.875rem;
    border-radius: 9999px;
  }

  .pricing-card-icon {
    width: 48px;
    height: 48px;
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
  }

  .pricing-card-icon--purple {
    background: var(--color-light-purple);
  }

  .pricing-card-icon--green {
    background: #ecfdf5;
  }

  .pricing-card-title {
    font-size: 1.375rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .pricing-card-desc {
    font-size: 0.9375rem;
    color: var(--color-muted);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .pricing-price {
    display: flex;
    align-items: baseline;
    gap: 0.125rem;
    margin-bottom: 0.25rem;
  }

  .pricing-currency {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-heading);
    align-self: flex-start;
    margin-top: 0.5rem;
  }

  .pricing-amount {
    font-size: 3rem;
    font-weight: 800;
    color: var(--color-heading);
    line-height: 1;
  }

  .pricing-amount--custom {
    font-size: 2.25rem;
    color: #10B981;
  }

  .pricing-period {
    font-size: 0.9375rem;
    color: var(--color-muted);
    font-weight: 500;
  }

  .pricing-setup {
    font-size: 0.875rem;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .pricing-setup strong {
    color: var(--color-heading);
  }

  .pricing-features {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2rem;
    flex: 1;
  }

  .pricing-features li {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.9375rem;
    color: var(--color-body);
  }

  .pricing-features li svg {
    flex-shrink: 0;
  }

  .pricing-btn {
    width: 100%;
    text-align: center;
    padding: 0.875rem;
    font-size: 0.9375rem;
  }

  .btn-dark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 0.875rem;
    background-color: #1a1a2e;
    color: var(--color-white);
    font-family: var(--font-family);
    font-size: 0.9375rem;
    font-weight: 600;
    border: none;
    border-radius: 9999px;
    cursor: pointer;
    transition: background-color var(--transition-fast);
    text-decoration: none;
  }

  .btn-dark:hover {
    background-color: #2d2d44;
  }

  /* CALCULATOR */
  .calculator-section {
    background: var(--color-white);
  }

  .calculator {
    background: linear-gradient(180deg, #fafaff 0%, #f5f5ff 100%);
    border-radius: 1.25rem;
    padding: 3rem 2rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .calc-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .calc-title {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .calc-subtitle {
    color: var(--color-muted);
    font-size: 1rem;
  }

  .calc-content {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .calc-input {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .calc-input label {
    font-size: 0.9rem;
    font-weight: 600;
    color: #3d3d5c;
  }

  .slider-wrap {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .calc-number-input {
    width: 90px;
    padding: 0.75rem 0.5rem;
    border: 2px solid #e8e8f0;
    border-radius: 10px;
    font-size: 1.25rem;
    font-weight: 700;
    text-align: center;
    color: var(--color-heading);
    font-family: inherit;
    transition: border-color var(--transition-fast);
    background: var(--color-white);
    outline: none;
    -moz-appearance: textfield;
  }

  .calc-number-input::-webkit-outer-spin-button,
  .calc-number-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .calc-number-input:focus {
    border-color: var(--color-primary);
  }

  .calc-slider {
    width: 180px;
    height: 8px;
    -webkit-appearance: none;
    appearance: none;
    background: #e8e8f0;
    border-radius: 4px;
    outline: none;
    border: none;
  }

  .calc-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 24px;
    height: 24px;
    background: var(--color-primary);
    border-radius: 50%;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(107, 78, 255, 0.3);
    transition: transform var(--transition-fast);
    border: none;
  }

  .calc-slider::-webkit-slider-thumb:hover {
    transform: scale(1.1);
  }

  .calc-slider::-moz-range-thumb {
    width: 24px;
    height: 24px;
    background: var(--color-primary);
    border-radius: 50%;
    cursor: pointer;
    border: none;
    box-shadow: 0 2px 8px rgba(107, 78, 255, 0.3);
  }

  .calc-result {
    background: var(--color-white);
    border-radius: 1rem;
    padding: 1.5rem 2rem;
    min-width: 300px;
    box-shadow: 0 4px 20px rgba(107, 78, 255, 0.08);
  }

  .result-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.625rem 0;
    border-bottom: 1px solid #f0f0f5;
  }

  .result-row--total {
    border-bottom: none;
    padding-top: 1rem;
    margin-top: 0.25rem;
  }

  .result-label {
    font-size: 0.9rem;
    color: var(--color-muted);
  }

  .result-value {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-heading);
  }

  .result-total {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .calc-cta {
    text-align: center;
    margin-top: 2rem;
  }

  /* FAQ */
  .faq-section {
    background: var(--color-white);
  }

  .faq-heading {
    text-align: center;
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 2.5rem;
  }

  .faq-list {
    max-width: 640px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .faq-item {
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    overflow: hidden;
    transition: border-color var(--transition-fast);
  }

  .faq-item[open] {
    border-color: var(--color-primary);
  }

  .faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-heading);
    cursor: pointer;
    list-style: none;
    user-select: none;
    transition: background-color var(--transition-fast);
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question::marker {
    display: none;
    content: '';
  }

  .faq-item[open] .faq-question {
    background: var(--color-primary);
    color: var(--color-white);
  }

  .faq-chevron {
    flex-shrink: 0;
    transition: transform var(--transition-base);
  }

  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
  }

  .faq-answer {
    padding: 1rem 1.25rem 1.25rem;
  }

  .faq-answer p {
    font-size: 0.9375rem;
    color: var(--color-muted);
    line-height: 1.7;
  }

  /* CTA */
  .pricing-cta {
    background: var(--color-white);
  }

  .pricing-cta-card {
    background: var(--color-light-bg);
    border: 1px solid var(--color-border);
    border-radius: 1.25rem;
    padding: 4rem 2rem;
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
  }

  .pricing-cta-card h2 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .pricing-cta-subtitle {
    font-size: 1rem;
    color: var(--color-muted);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  /* TABLET */
  @media (max-width: 1024px) {
    .pricing-cards {
      max-width: 700px;
    }
  }

  /* MOBILE */
  @media (max-width: 767px) {
    .pricing-hero {
      padding: 3rem 0 1.5rem;
    }

    .pricing-hero h1 {
      font-size: 2rem;
    }

    .pricing-cards {
      grid-template-columns: 1fr;
      max-width: 440px;
    }

    .calculator {
      padding: 2rem 1.5rem;
    }

    .calc-content {
      flex-direction: column;
    }

    .calc-result {
      width: 100%;
      min-width: auto;
    }

    .slider-wrap {
      flex-direction: column;
    }

    .calc-slider {
      width: 100%;
      max-width: 220px;
    }

    .faq-heading {
      font-size: 2rem;
    }

    .pricing-cta-card {
      padding: 3rem 1.5rem;
    }

    .pricing-cta-card h2 {
      font-size: 1.5rem;
    }
  }
</style>

<script>
  const slider = document.getElementById('calc-slider') as HTMLInputElement;
  const usersInput = document.getElementById('calc-users') as HTMLInputElement;
  const monthlyEl = document.getElementById('calc-monthly');
  const yearlyEl = document.getElementById('calc-yearly');

  if (slider && usersInput && monthlyEl && yearlyEl) {
    function updateCalc(users: number) {
      const pricePerUser = 0.29;
      const setupFee = 99;
      const monthly = users * pricePerUser;
      const yearly = monthly * 12 + setupFee;

      monthlyEl!.textContent = '$' + monthly.toFixed(2);
      yearlyEl!.textContent = '$' + yearly.toFixed(2);
    }

    slider.addEventListener('input', () => {
      usersInput.value = slider.value;
      updateCalc(parseInt(slider.value));
    });

    usersInput.addEventListener('input', () => {
      let val = parseInt(usersInput.value) || 5;
      val = Math.max(5, Math.min(1000, val));
      slider.value = String(Math.min(500, val));
      updateCalc(val);
    });

    updateCalc(25);
  }
</script>
